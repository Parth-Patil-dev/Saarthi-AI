# ─────────────────────────────────────────────
#  Server Configuration
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
#  AI Model Configuration
#  Choose ONE of the integration modes below:
# ─────────────────────────────────────────────

# Mode A: Local REST API (e.g. Ollama, LM Studio, llama.cpp server)
# Start your model server first, then set the URL below.
# Example for Ollama:  http://localhost:11434
# Example for LM Studio: http://localhost:1234
AI_MODE=rest                          # "rest" | "mock"
AI_REST_URL=http://localhost:11434    # Base URL of local model server
AI_MODEL_NAME=phi:latest                    # Model name as listed in your server

# API format used by your model server:
#   ollama  → POST /api/chat          (Ollama default port 11434)
#   openai  → POST /v1/chat/completions  (LM Studio port 1234, llama.cpp port 8080)
#   auto    → detected from port in AI_REST_URL (default)
AI_API_FORMAT=auto

# Mode B: Mock (no model needed – great for testing the API)
# AI_MODE=mock

# ─────────────────────────────────────────────
#  Conversation Memory
# ─────────────────────────────────────────────
# How many past message pairs to include for context
CONTEXT_WINDOW=6

# ─────────────────────────────────────────────
#  PDF Upload Settings
# ─────────────────────────────────────────────
# Maximum upload size in bytes (default: 10 MB)
PDF_MAX_SIZE_BYTES=10485760
# Folder where uploaded files are temporarily stored
UPLOAD_DIR=uploads
